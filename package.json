{
  "name": "transitland-vscode-extension",
  "displayName": "Transitland",
  "publisher": "interline-io",
  "repository": {
    "url": "https://github.com/transitland/transitland-atlas-vscode-extension"
  },
  "license": "GPL-3.0",
  "description": "GTFS feed tools, DMFR editing, and Transitland integration for VS Code.",
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.99.0",
    "node": ">=22"
  },
  "categories": [
    "Snippets",
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:dmfr",
    "onCommand:transitland.showWelcome",
    "onCommand:transitland.validateGtfsFeed",
    "onCommand:transitland.inspectGtfsFeed",
    "onCommand:transitland.inspectGtfsRtFeed"
  ],
  "extensionDependencies": [
    "vscode.json-language-features"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dmfr",
        "aliases": [
          "DMFR",
          "Distributed Mobility Feed Registry"
        ],
        "extensions": [
          ".dmfr.json"
        ]
      }
    ],
    "grammars": [
      {
        "language": "dmfr",
        "scopeName": "source.json.dmfr",
        "path": "./syntaxes/dmfr.tmLanguage.json"
      }
    ],
    "jsonLanguageParticipants": [
      {
        "languageId": "dmfr"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "*.dmfr.json",
        "url": "https://dmfr.transit.land/json-schema/dmfr.schema.json"
      }
    ],
    "configuration": {
      "title": "Transitland",
      "properties": {
        "transitland.apiKey": {
          "type": "string",
          "default": "",
          "description": "Transitland API key for feed status (CodeLens). Leave empty to use TRANSITLAND_API_KEY env var."
        },
        "transitland.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the transitland CLI binary. Leave empty to auto-detect from PATH (Homebrew, go install, etc.)."
        }
      }
    },
    "snippets": [
      {
        "language": "dmfr",
        "path": "./snippets.json"
      }
    ],
    "commands": [
      {
        "command": "transitland.showWelcome",
        "title": "Open Welcome / Launcher",
        "category": "Transitland"
      },
      {
        "command": "transitland.createNewDmfrFile",
        "title": "New DMFR File",
        "category": "Transitland"
      },
      {
        "command": "transitland.formatDmfrFile",
        "title": "Apply opinionated format to current DMFR file",
        "category": "Transitland",
        "enablement": "editorLangId == dmfr"
      },
      {
        "command": "transitland.validateGtfsFeed",
        "title": "Validate GTFS Feed…",
        "category": "Transitland"
      },
      {
        "command": "transitland.inspectGtfsFeed",
        "title": "Inspect GTFS Feed…",
        "category": "Transitland"
      },
      {
        "command": "transitland.inspectGtfsRtFeed",
        "title": "Inspect GTFS Realtime Feed…",
        "category": "Transitland"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "transitland.createNewDmfrFile",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "transitland.showWelcome"
        },
        {
          "command": "transitland.createNewDmfrFile"
        },
        {
          "command": "transitland.formatDmfrFile",
          "when": "editorLangId == dmfr"
        },
        {
          "command": "transitland.validateGtfsFeed"
        },
        {
          "command": "transitland.inspectGtfsFeed"
        },
        {
          "command": "transitland.inspectGtfsRtFeed"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run build",
    "build": "yarn run typecheck && node esbuild.mjs",
    "build:watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "pretest": "yarn run build && yarn run lint",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "bin": {
    "transitland-mcp": "./out/mcp-server.js"
  },
  "devDependencies": {
    "@types/glob": "^8.0.1",
    "@types/mocha": "^10.0.1",
    "@types/node": "22.x",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.33.0",
    "glob": "^8.1.0",
    "mocha": "^10.1.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "zod": "^3.22.0"
  }
}
